{
  "name": "webos",
  "version": "1.1.0",
  "private": true,
  "description": "通用 Web 桌面平台",
  "author": "MountCloud <mountcloud@outlook.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @webos/shell dev",
    "dev:examples": "pnpm --parallel --filter=example-vanilla-js-vite --filter=example-vue-js --filter=example-react-ts --filter=example-react-mui dev",
    "dev:all": "pnpm --parallel --filter=@webos/shell --filter=example-vanilla-js-vite --filter=example-vue-js --filter=example-react-ts --filter=example-react-mui dev",
    "build": "pnpm -r build",
    "build:shell": "pnpm --filter @webos/shell build",
    "build:packages": "pnpm --filter './packages/*' build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  }
}
