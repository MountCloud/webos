{
  "name": "@webos/mui-theme",
  "version": "0.1.0",
  "description": "把 webos 的设计 token 翻译成 MUI Theme，并自动跟随桌面壳主题切换",
  "author": "MountCloud <mountcloud@outlook.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/mui-theme.cjs.js",
  "module": "./dist/mui-theme.esm.js",
  "types": "./dist/mui-theme.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mui-theme.esm.js",
      "require": "./dist/mui-theme.cjs.js",
      "types": "./dist/mui-theme.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@mui/material": "^5.0.0 || ^6.0.0",
    "@webos/host-sdk": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "@webos/host-sdk": { "optional": true }
  },
  "devDependencies": {
    "@mui/material": "^5.16.0",
    "@webos/host-sdk": "workspace:*",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "rollup": "^4.18.0",
    "rollup-plugin-dts": "^6.1.1",
    "tslib": "^2.6.2",
    "typescript": "^5.4.0"
  }
}
