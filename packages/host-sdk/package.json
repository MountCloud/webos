{
  "name": "@webos/host-sdk",
  "version": "0.1.0",
  "description": "webos 应用 SDK - 让任何 Web 应用接入 webos 桌面运行时",
  "author": "MountCloud <mountcloud@outlook.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/host-sdk.cjs.js",
  "module": "./dist/host-sdk.esm.js",
  "browser": "./dist/host-sdk.umd.js",
  "types": "./dist/host-sdk.d.ts",
  "exports": {
    ".": {
      "import": "./dist/host-sdk.esm.js",
      "require": "./dist/host-sdk.cjs.js",
      "types": "./dist/host-sdk.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "rollup": "^4.18.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "rollup-plugin-dts": "^6.1.1",
    "typescript": "^5.4.0",
    "tslib": "^2.6.2"
  }
}
